# Task:
# Extract product data from a website and save it as a dataset (CSV)
#
# Libraries Needed:
# pip install requests beautifulsoup4 pandas
#
# Example Website:
# http://books.toscrape.com
# (This website is made for web scraping practice)
# ============================================

import requests
from bs4 import BeautifulSoup
import pandas as pd

# Website URL
url = "http://books.toscrape.com/catalogue/page-1.html"

# Store extracted data
books_data = []

# Loop through multiple pages
for page in range(1, 6):   # Scraping first 5 pages
    
    print(f"Scraping Page {page}...")
    
    page_url = f"http://books.toscrape.com/catalogue/page-{page}.html"
    
    # Send HTTP request
    response = requests.get(page_url)
    
    # Parse HTML content
    soup = BeautifulSoup(response.text, "html.parser")
    
    # Find all book containers
    books = soup.find_all("article", class_="product_pod")
    
    # Extract data from each book
    for book in books:
        
        # Book title
        title = book.h3.a["title"]
        
        # Book price
        price = book.find("p", class_="price_color").text
        
        # Stock availability
        availability = book.find("p", class_="instock availability").text.strip()
        
        # Rating
        rating = book.p["class"][1]
        
        # Append to dataset
        books_data.append({
            "Title": title,
            "Price": price,
            "Availability": availability,
            "Rating": rating
        })

# Convert to DataFrame
df = pd.DataFrame(books_data)

# Display first few rows
print("\nScraped Data:")
print(df.head())

# Save dataset as CSV
df.to_csv("books_dataset.csv", index=False)

print("\nDataset saved as books_dataset.csv")
